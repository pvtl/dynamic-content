{
    "name": "pvtl/dynamic-content",
    "description": "Dynamic content management with configurable sections for Laravel Livewire and Flux UI applications",
    "type": "library",
    "license": "MIT",
    "version": "1.0.1",
    "require": {
        "php": "^8.4",
        "illuminate/support": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/console": "^13.0",
        "livewire/livewire": "^4.0",
        "livewire/flux": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Pvtl\\DynamicContent\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pvtl\\DynamicContent\\DynamicContentServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
